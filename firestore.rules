rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Properties collection - allow all reads and writes for development
    match /properties/{docId} {
      allow read, write: if true;
    }

    // Blogs collection - allow all reads and writes for development
    match /blogs/{docId} {
      allow read, write: if true;
    }

    // Inquiries collection - allow all reads and writes for development
    match /inquiries/{docId} {
      allow read, write: if true;
    }
  }
}
